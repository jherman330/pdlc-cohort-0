{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "IdempotencyCache": {
    "Enabled": true,
    "TtlHours": 24,
    "KeyPrefix": "idempotency:"
  },
  "Redis": {
    "ConnectionString": ""
  },
  "ApiVersioning": {
    "DefaultVersion": "1.0",
    "UrlPattern": "api/v{version:apiVersion}"
  },
  "Cors": {
    "AllowedOrigins": ["*"],
    "AllowedMethods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
    "AllowedHeaders": ["*"]
  },
  "HealthChecks": {
    "Enabled": true,
    "TimeoutSeconds": 5
  },
  "CosmosDb": {
    "Endpoint": "",
    "DatabaseName": "",
    "Key": "",
    "MaxConnectionLimit": 50,
    "RequestTimeout": 60,
    "ContainerNames": {
      "AssetInventory": "AssetInventory",
      "LicenseAllocations": "LicenseAllocations",
      "Events": "Events"
    }
  },
  "AzureSql": {
    "ConnectionString": "",
    "DatabaseName": "",
    "CommandTimeoutSeconds": 30,
    "EnableRetryOnFailure": true,
    "MaxRetryCount": 3,
    "MaxPoolSize": 0,
    "ConnectionTimeout": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      { "Name": "Console" }
    ]
  }
}
