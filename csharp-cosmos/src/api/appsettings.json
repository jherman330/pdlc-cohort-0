{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "todo-api",
    "Audience": "todo-api-clients",
    "SigningKey": "LOCAL_TEMPLATE_REPLACE_WITH_SECRET_MIN_32_CHARS_LONG!",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 14
  },
  "BootstrapAuth": {
    "Users": []
  },
  "IdempotencyCache": {
    "Enabled": true,
    "TtlHours": 24,
    "KeyPrefix": "idempotency:"
  },
  "Redis": {
    "ConnectionString": ""
  },
  "ApiVersioning": {
    "DefaultVersion": "1.0",
    "UrlPattern": "api/v{version:apiVersion}"
  },
  "Cors": {
    "AllowedOrigins": ["*"],
    "AllowedMethods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
    "AllowedHeaders": ["*"]
  },
  "HealthChecks": {
    "Enabled": true,
    "TimeoutSeconds": 5
  },
  "CosmosDb": {
    "Endpoint": "",
    "DatabaseName": "",
    "Key": "",
    "MaxConnectionLimit": 50,
    "RequestTimeout": 60,
    "EnableCertificatePinning": false,
    "PinnedCertificateThumbprints": [],
    "ContainerNames": {
      "AssetInventory": "AssetInventory",
      "LicenseAllocations": "LicenseAllocations",
      "Events": "Events"
    }
  },
  "AzureSql": {
    "ConnectionString": "",
    "DatabaseName": "",
    "CommandTimeoutSeconds": 30,
    "EnableRetryOnFailure": true,
    "MaxRetryCount": 3,
    "MaxPoolSize": 0,
    "ConnectionTimeout": 30,
    "DefaultTenantId": ""
  },
  "PiiEncryption": {
    "EncryptionKeyBase64": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      { "Name": "Console" }
    ]
  }
}
