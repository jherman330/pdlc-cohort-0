{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft": "Information",
      "System": "Information"
    }
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000", "http://localhost:5173", "http://localhost:8080", "https://localhost:5001", "http://localhost:5000"]
  },
  "HealthChecks": {
    "Enabled": true,
    "TimeoutSeconds": 10
